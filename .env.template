# Required
METACULUS_TOKEN=1234567890

# Optional
OPENROUTER_API_KEY=1234567890
# Metaculus-donated OpenRouter key. Despite the name, server-side allowed-
# providers preferences cover OpenAI, Anthropic, AND Google models — the
# donated credits route through this key for all three. Non-listed providers
# (e.g. x-ai for Grok) 404 on this key and fall back to OPENROUTER_API_KEY.
OAI_ANTH_OPENROUTER_KEY=1234567890
ASKNEWS_CLIENT_ID=1234567890
ASKNEWS_SECRET=1234567890
# AskNews recommended safe defaults for development/local runs
# Concurrency=1 ensures only one in-flight call at a time across all models
# Max RPS=0.2 enforces ~5s between calls to avoid minute-level rate bursts
# Tries/backoff handle transient 429s gracefully without spiking traffic
ASKNEWS_MAX_CONCURRENCY=1
ASKNEWS_MAX_RPS=0.2
ASKNEWS_MAX_TRIES=3
ASKNEWS_BACKOFF_SECS=2.0
ANTHROPIC_API_KEY=1234567890

# Financial data provider (yfinance + FRED) for economic/market questions
# FINANCIAL_DATA_ENABLED=true
# FRED_API_KEY=your_free_key_from_fred.stlouisfed.org

# Native web search via OpenRouter (Grok 4.1 fast :online)
# NATIVE_SEARCH_ENABLED=true
# NATIVE_SEARCH_MODEL=x-ai/grok-4.1-fast

# Gemini grounded search via Google AI Studio (first-party Google Search index)
# Adds a third distinct research source alongside AskNews + Grok. Requires a
# Google AI Studio API key with billing enabled to unlock Gemini 3 Flash
# grounding (falls back to gemini-2.5-flash on free tier). The 5k/month free
# grounded-prompt bucket is shared across the Gemini 3 family; realistic spend
# stays at $0-5 for typical tournament volume.
# GOOGLE_API_KEY is the operator's personal Google AI Studio key (in CI it's
# stored as the GEMINI_API_KEY secret and surfaced as GOOGLE_API_KEY for the
# google-genai SDK). The grounded-search side has no donated/shared key path —
# Google AI Studio doesn't offer one — so this env var is always personal.
# GOOGLE_API_KEY=1234567890
# GEMINI_SEARCH_ENABLED=true
# GEMINI_SEARCH_MODEL=gemini-3-flash-preview

# GEMINI_USE_DONATED_OPENROUTER_KEY=false
# Toggle for OpenRouter Gemini routing only (does NOT affect grounded search).
# When 'true', OpenRouter Gemini calls flow through the Metaculus-donated
# OAI_ANTH_OPENROUTER_KEY with paid-key fallback. When 'false' (default), they
# route through OPENROUTER_API_KEY only — bypassing the donated wrapper because
# the donated-key Google route has been flaky.

# Second-pass gap-fill research (requires GOOGLE_API_KEY)
# Runs after first-pass research completes. An analyzer call identifies up to 5
# factual gaps; each is resolved via a parallel grounded Gemini search. Fails
# soft — forecast proceeds with first-pass research alone if anything errors.
# GAP_FILL_ENABLED=true

# Disable OpenAI Agents SDK trace-export (we route via OpenRouter, not OpenAI)
OPENAI_AGENTS_DISABLE_TRACING=true

# Disable numeric stacking (n=88 ablation showed it hurts CRPS)
NUMERIC_STACKING_ENABLED=false

# Prediction-market snapshot timeout (runs in parallel with other research)
# PREDICTION_MARKET_TIMEOUT=30
